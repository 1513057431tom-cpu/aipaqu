# Application
APP_ENV=development
APP_PUBLIC_URL=http://localhost:3000
APP_TIMEZONE=Asia/Shanghai
ALLOWED_ORIGINS=http://localhost:3000

# Security
SESSION_SECRET=replace-with-random-session-secret
MASTER_ENCRYPTION_KEY=replace-with-random-32-byte-key
CSRF_COOKIE_NAME=csrf_token

# Data stores
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=intelligence_reports
MYSQL_USER=app
MYSQL_PASSWORD=replace-with-local-password
REDIS_URL=redis://redis:6379/0
ELASTICSEARCH_URL=http://elasticsearch:9200

# Models
LLM_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace-with-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
EMBEDDING_PROVIDER=local

# Files
FILE_STORAGE_PATH=/app/storage
MAX_UPLOAD_MB=50

# Crawling
CRAWLER_MAX_CONCURRENCY=4
CRAWLER_REQUEST_TIMEOUT_SECONDS=30

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_DEFAULT_SENDER=reports@example.com
